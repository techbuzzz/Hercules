{
  "Llm": {
    "Provider": "yandexgpt",
    "Fallback": [ "ollama-cloud", "ollama-local" ],
    "YandexGpt": {
      "Endpoint": "https://llm.api.cloud.yandex.net/v1",
      "ApiKey": "ВСТАВЬТЕ_IAM_ИЛИ_API_КЛЮЧ",
      "FolderId": "ВСТАВЬТЕ_FOLDER_ID",
      "Model": "yandexgpt",
      "Temperature": 0.6,
      "MaxTokens": 2000
    },
    "OllamaCloud": {
      "Endpoint": "https://ollama.com/v1",
      "ApiKey": "ВСТАВЬТЕ_OLLAMA_CLOUD_KEY",
      "Model": "gpt-oss:120b",
      "Temperature": 0.6,
      "MaxTokens": 2000
    },
    "OllamaLocal": {
      "Endpoint": "http://localhost:11434/v1",
      "ApiKey": "",
      "Model": "llama3.1",
      "Temperature": 0.6,
      "MaxTokens": 2000
    }
  },
  "Storage": {
    "DataRoot": "data",
    "SkillsDir": "Skills",
    "MemoryDir": "Memory",
    "SqliteFile": "sessions.db"
  },
  "Agent": {
    "SystemPrompt": "Ты — Hercules, самообучающийся ассистент. Отвечай кратко, по делу и на русском языке.",
    "SkillCreationThreshold": 3,
    "SkillImprovementThreshold": 0.6,
    "SkillEvaluationWindow": 5,
    "ReflectionEveryNCommands": 10
  },
  "Telegram": {
    "Enabled": false,
    "BotToken": ""
  }
}
