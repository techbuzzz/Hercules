{
  "Llm": {
    "Provider": "yandexgpt",
    "Fallback": [ "ollama-cloud", "ollama-local" ],
    "YandexGpt": {
      "Endpoint": "https://llm.api.cloud.yandex.net/v1",
      "ApiKey": "ВСТАВЬТЕ_IAM_ИЛИ_API_КЛЮЧ",
      "FolderId": "ВСТАВЬТЕ_FOLDER_ID",
      "Model": "yandexgpt",
      "Temperature": 0.6,
      "MaxTokens": 2000
    },
    "OllamaCloud": {
      "Endpoint": "https://ollama.com/v1",
      "ApiKey": "ВСТАВЬТЕ_OLLAMA_CLOUD_KEY",
      "Model": "gpt-oss:120b",
      "Temperature": 0.6,
      "MaxTokens": 2000
    },
    "OllamaLocal": {
      "Endpoint": "http://localhost:11434/v1",
      "ApiKey": "",
      "Model": "llama3.1",
      "Temperature": 0.6,
      "MaxTokens": 2000
    }
  },
  "Storage": {
    "DataRoot": "data",
    "SkillsDir": "Skills",
    "MemoryDir": "Memory",
    "SqliteFile": "sessions.db"
  },
  "Agent": {
    "SystemPrompt": "Ты — Hercules, самообучающийся ассистент. Отвечай кратко, по делу и на русском языке.",
    "SkillCreationThreshold": 3,
    "SkillImprovementThreshold": 0.6,
    "SkillEvaluationWindow": 5,
    "ReflectionEveryNCommands": 10
  },
  "Telegram": {
    "Enabled": false,
    "BotToken": ""
  },
  "CodeExecution": {
    "CpuTimeoutSeconds": 30,
    "MaxFileSizeMb": 10,
    "MaxProcesses": 0,
    "MaxOpenFiles": 1024,
    "MaxVirtualMemoryMb": 0,
    "AllowNetwork": false,
    "MaxCodeSizeKb": 100,
    "SessionTtlSeconds": 3600,
    "TempRoot": ""
  },
  "Http": {
    "AllowedDomains": ["*"],
    "RateLimitPerMinute": 60,
    "TimeoutSeconds": 10,
    "MaxResponseSizeKb": 256
  },
  "Mcp": {
    "Servers": []
  },
  "A2A": {
    "Endpoints": {},
    "TimeoutSeconds": 30
  },
  "Roles": {
    "main": { "Provider": "yandexgpt", "Temperature": 0.6 },
    "code_writer": { "Provider": "yandexgpt", "Temperature": 0.2, "MaxTokens": 2000 },
    "reflector":  { "Provider": "ollama-local", "Model": "llama3.1", "Temperature": 0.0, "MaxTokens": 1500 }
  }
}
