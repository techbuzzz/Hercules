---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hercules · Навыки" active="skills">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1 class="text-xl font-semibold text-white">Навыки</h1>
      <p class="text-sm text-gray-400">Просмотр, создание и улучшение навыков агента.</p>
    </div>
    <button
      id="new-skill-btn"
      type="button"
      class="rounded-xl bg-emerald-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-emerald-500"
    >
      + Новый навык
    </button>
  </div>

  <!-- Форма создания/редактирования -->
  <div id="skill-form" class="mb-6 hidden rounded-xl border border-white/10 bg-[#101012] p-4">
    <h2 id="form-title" class="mb-3 font-medium text-white">Новый навык</h2>
    <input type="hidden" id="f-id" />
    <div class="grid gap-3 sm:grid-cols-2">
      <label class="flex flex-col gap-1 text-xs text-gray-400">
        Имя
        <input id="f-name" type="text" class="rounded-lg border border-white/10 bg-[#0a0a0b] px-3 py-2 text-sm text-gray-100 outline-none focus:border-emerald-500/50" placeholder="Например: Погода" />
      </label>
      <label class="flex flex-col gap-1 text-xs text-gray-400">
        Триггеры (через запятую)
        <input id="f-triggers" type="text" class="mono rounded-lg border border-white/10 bg-[#0a0a0b] px-3 py-2 text-sm text-gray-100 outline-none focus:border-emerald-500/50" placeholder="погода, прогноз, температура" />
      </label>
    </div>
    <label class="mt-3 flex flex-col gap-1 text-xs text-gray-400">
      Описание
      <input id="f-desc" type="text" class="rounded-lg border border-white/10 bg-[#0a0a0b] px-3 py-2 text-sm text-gray-100 outline-none focus:border-emerald-500/50" placeholder="Краткое описание навыка" />
    </label>
    <label class="mt-3 flex flex-col gap-1 text-xs text-gray-400">
      Системный промпт
      <textarea id="f-prompt" rows="5" class="mono rounded-lg border border-white/10 bg-[#0a0a0b] px-3 py-2 text-sm text-gray-100 outline-none focus:border-emerald-500/50" placeholder="Инструкция, как агент должен отвечать при срабатывании навыка…"></textarea>
    </label>
    <div class="mt-4 flex items-center gap-2">
      <button id="f-save" type="button" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-500 disabled:opacity-50">Сохранить</button>
      <button id="f-cancel" type="button" class="rounded-lg border border-white/10 px-4 py-2 text-sm text-gray-200 hover:bg-white/5">Отмена</button>
      <span id="f-status" class="ml-2 text-xs text-gray-500"></span>
    </div>
  </div>

  <div id="skills-grid" class="grid gap-4 sm:grid-cols-2">
    <div class="text-sm text-gray-500">Загрузка навыков…</div>
  </div>
</Layout>

<script>
  import { api } from "../lib/api";
  import type { SkillDto } from "../lib/api";

  const grid = document.getElementById("skills-grid")!;
  const formBox = document.getElementById("skill-form")!;
  const formTitle = document.getElementById("form-title")!;
  const fId = document.getElementById("f-id") as HTMLInputElement;
  const fName = document.getElementById("f-name") as HTMLInputElement;
  const fTriggers = document.getElementById("f-triggers") as HTMLInputElement;
  const fDesc = document.getElementById("f-desc") as HTMLInputElement;
  const fPrompt = document.getElementById("f-prompt") as HTMLTextAreaElement;
  const fStatus = document.getElementById("f-status")!;
  const fSave = document.getElementById("f-save") as HTMLButtonElement;

  function esc(s: string) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  function rateColor(r: number) {
    return r >= 70 ? "text-emerald-400" : r >= 40 ? "text-amber-400" : "text-rose-400";
  }
  function barColor(r: number) {
    return r >= 70 ? "bg-emerald-500" : r >= 40 ? "bg-amber-500" : "bg-rose-500";
  }

  function cardHtml(s: SkillDto): string {
    const rate = Math.round((s.successRate ?? 0) * 100);
    const triggers = s.triggers.map((t) => `<span class="mono rounded bg-white/5 px-2 py-0.5 text-[11px] text-gray-300">${esc(t)}</span>`).join("");
    return `
      <div class="flex flex-col gap-3 rounded-xl border border-white/10 bg-[#101012] p-4 transition-colors hover:border-white/20">
        <div class="flex items-start justify-between gap-2">
          <div>
            <h3 class="font-semibold text-white">${esc(s.name)}</h3>
            ${s.description ? `<p class="mt-0.5 text-xs text-gray-400">${esc(s.description)}</p>` : ""}
          </div>
          <span class="mono shrink-0 rounded bg-violet-500/15 px-2 py-0.5 text-[11px] text-violet-300">v${s.version}</span>
        </div>
        <div class="flex flex-wrap gap-1.5">${triggers}</div>
        <div class="flex items-center gap-4 text-xs text-gray-400">
          <span>Успех: <span class="${rateColor(rate)}">${rate}%</span></span>
          <span>Использований: <span class="text-gray-200">${s.totalUses}</span></span>
        </div>
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-white/5">
          <div class="h-full rounded-full ${barColor(rate)}" style="width:${Math.max(rate, 2)}%"></div>
        </div>
        <div class="flex gap-2 pt-1">
          <button type="button" data-edit="${s.id}" class="rounded-lg border border-white/10 px-3 py-1.5 text-xs text-gray-200 transition-colors hover:bg-white/5">Редактировать</button>
          <button type="button" data-improve="${s.id}" class="rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-1.5 text-xs text-amber-200 transition-colors hover:bg-amber-500/20">Улучшить (ИИ)</button>
        </div>
      </div>`;
  }

  let cache: SkillDto[] = [];

  async function load() {
    try {
      cache = await api.listSkills();
      if (cache.length === 0) {
        grid.innerHTML = `<div class="text-sm text-gray-500">Навыков пока нет. Создайте первый навык кнопкой «+ Новый навык».</div>`;
        return;
      }
      grid.innerHTML = cache.map(cardHtml).join("");
      bindCards();
    } catch (e) {
      grid.innerHTML = `<div class="rounded-xl border border-rose-500/40 bg-rose-500/10 px-4 py-3 text-sm text-rose-200">Ошибка загрузки: ${esc(e instanceof Error ? e.message : String(e))}</div>`;
    }
  }

  function bindCards() {
    grid.querySelectorAll<HTMLButtonElement>("[data-edit]").forEach((b) =>
      b.addEventListener("click", () => openEdit(b.dataset.edit!))
    );
    grid.querySelectorAll<HTMLButtonElement>("[data-improve]").forEach((b) =>
      b.addEventListener("click", () => improve(b.dataset.improve!, b))
    );
  }

  function openCreate() {
    fId.value = "";
    fName.value = "";
    fTriggers.value = "";
    fDesc.value = "";
    fPrompt.value = "";
    fName.disabled = false;
    formTitle.textContent = "Новый навык";
    fStatus.textContent = "";
    formBox.classList.remove("hidden");
    formBox.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  async function openEdit(id: string) {
    fStatus.textContent = "Загрузка…";
    formBox.classList.remove("hidden");
    try {
      const d = await api.getSkill(id);
      fId.value = d.meta.id;
      fName.value = d.meta.name;
      fName.disabled = true; // имя навыка не меняем
      fTriggers.value = d.meta.triggers.join(", ");
      fDesc.value = d.meta.description || "";
      fPrompt.value = d.prompt || "";
      formTitle.textContent = "Редактирование: " + d.meta.name;
      fStatus.textContent = "";
      formBox.scrollIntoView({ behavior: "smooth", block: "center" });
    } catch (e) {
      fStatus.textContent = "Ошибка: " + (e instanceof Error ? e.message : e);
    }
  }

  async function improve(id: string, btn: HTMLButtonElement) {
    if (!confirm("Запустить улучшение навыка с помощью ИИ? Будет создана новая версия.")) return;
    const old = btn.textContent;
    btn.disabled = true;
    btn.textContent = "Улучшение…";
    try {
      await fetch(`${(await import("../lib/api")).API_BASE}/api/skills/${id}/improve`, {
        method: "POST",
        headers: { "X-Api-Key": (await import("../lib/api")).API_KEY },
      }).then((r) => { if (!r.ok) throw new Error("HTTP " + r.status); });
      await load();
    } catch (e) {
      alert("Ошибка улучшения: " + (e instanceof Error ? e.message : e));
      btn.disabled = false;
      btn.textContent = old;
    }
  }

  fSave.addEventListener("click", async () => {
    const triggers = fTriggers.value.split(",").map((t) => t.trim()).filter(Boolean);
    fSave.disabled = true;
    fStatus.textContent = "Сохранение…";
    try {
      if (fId.value) {
        await api.updateSkill(fId.value, { triggers, prompt: fPrompt.value, description: fDesc.value });
      } else {
        if (!fName.value.trim()) { fStatus.textContent = "Укажите имя"; fSave.disabled = false; return; }
        await api.createSkill({ name: fName.value.trim(), trigger: triggers.join(","), prompt: fPrompt.value, description: fDesc.value });
      }
      formBox.classList.add("hidden");
      await load();
    } catch (e) {
      fStatus.textContent = "Ошибка: " + (e instanceof Error ? e.message : e);
    } finally {
      fSave.disabled = false;
    }
  });

  document.getElementById("new-skill-btn")!.addEventListener("click", openCreate);
  document.getElementById("f-cancel")!.addEventListener("click", () => formBox.classList.add("hidden"));

  load();
</script>
